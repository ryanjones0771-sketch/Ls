# ---------- DATA FILE ----------
def get_data_file(token: str) -> str:
    safe = "".join(c for c in token if c.isalnum())[:10]
    return f"owner_data_{safe}.json"

def default_data() -> dict:
    return {
        "owner_id": OWNER_ID,
        "admins": [],
        "prefix": "/",
        "chats": {},
        "known_groups": [],
        "premium_emoji_id": None,
        "message_delay": 0,
